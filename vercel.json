{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "crons": [
    { "path": "/api/refresh-matview", "schedule": "0 3 * * *" },
    { "path": "/api/check-quota", "schedule": "0 4 * * *" }
  ]
}
