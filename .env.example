# =============================================================================
# hana-memo .env.example
# =============================================================================
# 利用方法: cp .env.example .env.local → 実値を埋める
# 重要: .env.local は .gitignore で除外済、絶対にコミットしないこと
# 関連: concept.md §4.5.3、PREREQUISITES.md §9、SECURITY_REVIEW_20260523.md [SEC-002]
# =============================================================================

# === Server-side only (Vercel Function env、frontend に露出禁止) ===

# OpenAI API (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Neon Postgres (https://console.neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Clerk (https://dashboard.clerk.com/last-active/api-keys)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare R2 (https://dash.cloudflare.com > R2 > Manage API Tokens)
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=hana-memo-plant-images

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry (Server-side DSN、opt-in user のみ送信、PII scrub 必須)
SENTRY_DSN=https://xxxxxxxxxxxxxxxxx@o000000.ingest.sentry.io/0000000

# Slack Webhooks (アラート + 月次収益通知)
SLACK_QUOTA_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
SLACK_REVENUE_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Vercel Cron 認証 (cron handler が Authorization: Bearer <CRON_SECRET> を検証)
CRON_SECRET=replace-with-a-long-random-string

# Upstash Ratelimit ([SEC-001] revise 由来、Redis REST API)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile (将来用、匿名 user SPAM 抑止)
# TURNSTILE_SECRET_KEY=0x4XXxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Client-side (VITE_ プレフィックス、frontend バンドルに含まれる) ===

VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxx@o000000.ingest.sentry.io/0000000

# Cloudflare Turnstile (frontend、将来用)
# VITE_TURNSTILE_SITE_KEY=0x4XXxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Cost rates (concept §4.5.3、コスト追跡用、本番運用前に最新値で更新) ===

COST_OPENAI_GPT4O_MINI_PER_1K_INPUT_TOKENS=0.00015
COST_OPENAI_GPT4O_MINI_PER_1K_OUTPUT_TOKENS=0.0006
COST_OPENAI_GPT4O_MINI_PER_IMAGE=0.001
COST_R2_PER_GB_PER_MONTH=0.015
COST_R2_EGRESS_PER_GB=0
COST_NEON_PER_COMPUTE_HOUR=0.16
COST_CLERK_PER_MAU_OVERAGE=0.02

# === Monthly budget threshold (Slack 通知発火、§4.6.2) ===

OPENAI_MONTHLY_BUDGET_USD=30
